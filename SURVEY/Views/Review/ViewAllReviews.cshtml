@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"];
}
<head>
    <link rel="stylesheet" href="~/css/Reviews.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<div class="dashboard-page">
    <div class="unified-section">

        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="header-left">
                <div class="hero-badge">@Localizer["HeroBadge"]</div>
                <h1><span class="highlight">@Localizer["PageHeadline"]</span></h1>
                <p>@Localizer["PageDescription"]</p>
            </div>
            <div class="header-right">
                <button class="btn-export" id="exportBtn">
                    @Localizer["ExportButton"]
                </button>
            </div>
        </div>

        <!-- FILTER BAR - TÌM KIẾM & LỌC -->
        <div class="filter-section">
            <div class="filter-grid">
                <div class="filter-item">
                    <label>@Localizer["EmployeeCodeLabel"]</label>
                    <input type="text" id="searchEmployeeId" placeholder="@Localizer["EmployeeCodePlaceholder"]" class="filter-input">
                </div>
                <div class="filter-item">
                    <label>@Localizer["GroupLabel"]</label>
                    <input type="text" id="searchGroup" placeholder="@Localizer["GroupPlaceholder"]" class="filter-input">
                </div>
                <div class="filter-item">
                    <label>@Localizer["FromDateLabel"]</label>
                    <input type="date" id="dateFrom" class="filter-input">
                </div>
                <div class="filter-item">
                    <label>@Localizer["ToDateLabel"]</label>
                    <input type="date" id="dateTo" class="filter-input">
                </div>
                <div class="filter-actions">
                    <button class="btn-search" id="searchBtn">
                        @Localizer["SearchButton"]
                    </button>
                    <button class="btn-reset" id="resetBtn">
                        @Localizer["ResetButton"]
                    </button>
                </div>
            </div>
        </div>

        <!-- STATISTICS CARDS -->
@*         <div class="stats-section">
            <div class="stat-card">
                <div class="stat-icon">📋</div>
                <div class="stat-info">
                    <span class="stat-value" id="totalReviews">0</span>
                    <span class="stat-label">Tổng đánh giá</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">👥</div>
                <div class="stat-info">
                    <span class="stat-value" id="totalEmployees">0</span>
                    <span class="stat-label">Nhân viên được đánh giá</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">⭐</div>
                <div class="stat-info">
                    <span class="stat-value" id="avgScore">0.0</span>
                    <span class="stat-label">Điểm trung bình</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">📊</div>
                <div class="stat-info">
                    <span class="stat-value" id="totalGroups">0</span>
                    <span class="stat-label">Số nhóm tham gia</span>
                </div>
            </div>
        </div> *@

        <!-- DATA TABLE -->
        <div class="table-section">
            <div class="table-header">
                <h3>@Localizer["TableTitle"]</h3>
                <div class="table-info">
                    @Localizer["ShowingText"] <span id="showingCount">0</span> / <span id="totalCount">0</span> @Localizer["RecordsSuffix"]
                </div>
            </div>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th rowspan="2">@Localizer["ColNo"]</th>
                            <th rowspan="2">@Localizer["ColEmployeeCode"]</th>
                            <th rowspan="2">@Localizer["ColGroup"]</th>
                            <th rowspan="2">@Localizer["ColTime"]</th>
                            <th colspan="5">@Localizer["Group1Header"]</th>
                            <th colspan="5">@Localizer["Group2Header"]</th>
                            <th colspan="5">@Localizer["Group3Header"]</th>
                            <th colspan="5">@Localizer["Group4Header"]</th>
                            <th colspan="5">@Localizer["Group5Header"]</th>
                            <th rowspan="2">@Localizer["ColProposal"]</th>
                            <th rowspan="2">@Localizer["ColAvgScore"]</th>
                            <th rowspan="2">@Localizer["ColAction"]</th>
                        </tr>
                        <tr>
                            <th>@Localizer["ColStrength"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColNeedImprove"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColSituation"]</th>

                            <th>@Localizer["ColStrength"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColNeedImprove"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColSituation"]</th>

                            <th>@Localizer["ColStrength"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColNeedImprove"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColSituation"]</th>

                            <th>@Localizer["ColStrength"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColNeedImprove"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColSituation"]</th>

                            <th>@Localizer["ColStrength"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColNeedImprove"]</th>
                            <th>@Localizer["ColScore"]</th>
                            <th>@Localizer["ColSituation"]</th>
                        </tr>
                    </thead>
                    <tbody id="reviewsTableBody">
                        <!-- Dữ liệu sẽ được load bằng JavaScript -->
                        <tr class="loading-row">
                            <td colspan="32" style="text-align: center; padding: 60px;">
                                <div class="loading-spinner"></div>
                                <p>@Localizer["LoadingText"]</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- PAGINATION -->
            <div class="pagination-section">
                <div class="pagination-info">
                    <select id="pageSizeSelect">
                        <option value="10">@Localizer["PageSize10"]</option>
                        <option value="25">@Localizer["PageSize25"]</option>
                        <option value="50">@Localizer["PageSize50"]</option>
                        <option value="100">@Localizer["PageSize100"]</option>
                    </select>
                </div>
                <div class="pagination-controls" id="paginationControls">
                    <button class="page-btn" data-page="prev" disabled>@Localizer["PrevButton"]</button>
                    <span class="page-numbers" id="pageNumbers"></span>
                    <button class="page-btn" data-page="next">@Localizer["NextButton"]</button>
                </div>
            </div>
        </div>

        <!-- MODAL XEM CHI TIẾT -->
        <div id="detailModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>@Localizer["ModalTitle"]</h3>
                    <span class="modal-close">&times;</span>
                </div>
                <div class="modal-body" id="modalBody">
                    <!-- Nội dung chi tiết sẽ load bằng JS -->
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/Reviews.js" asp-append-version="true"></script>
}