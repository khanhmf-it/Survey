@using System.Globalization
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@inject SURVEY.Service.Services.Interfaces.IAuthenticationService AuthenticationService

@{
    var userAdid = User.Identity?.Name?.Split('\\').LastOrDefault() ?? "";
    var canViewReviews = false;

    if (!string.IsNullOrWhiteSpace(userAdid))
    {
        if (userAdid.Contains('\\'))
        {
            userAdid = userAdid.Split('\\').Last();
        }

        var checkUserResponse = await AuthenticationService.CheckUserExistAsync(userAdid);
        canViewReviews = checkUserResponse.Success && checkUserResponse.Data;
    }
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer["AppName"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SURVEY.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <div class="d-flex align-items-center gap-3">
                    <a class="navbar-brand mb-0" asp-area="" asp-controller="Home" asp-action="Index">
                        @Localizer["AppName"]
                    </a>

                    @if (canViewReviews)
                    {
                        <a class="nav-link text-dark fw-semibold"
                           asp-area=""
                           asp-controller="Review"
                           asp-action="ViewAllReviews">
                            @Localizer["Reviews"]
                        </a>
                    }
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <span class="text-muted small">@Localizer["Language"]:</span>

                    <a class="btn btn-outline-primary btn-sm"
                       asp-controller="Home"
                       asp-action="SetLanguage"
                       asp-route-culture="vi"
                       asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")">
                        🇻🇳
                    </a>

                    <a class="btn btn-outline-primary btn-sm"
                       asp-controller="Home"
                       asp-action="SetLanguage"
                       asp-route-culture="ja"
                       asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")">
                        🇯🇵
                    </a>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
