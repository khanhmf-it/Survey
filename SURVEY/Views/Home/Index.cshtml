@{
    ViewData["Title"] = "Đánh giá";
}
<head>
    <link rel="stylesheet" href="~/css/Index.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<div class="survey-page">
    <form method="post">
        <div class="unified-section">

            <!-- PHẦN 1: MỤC ĐÍCH - Dạng Hero -->
            <div class="purpose-hero">
                <div class="hero-badge">📋 KHẢO SÁT ĐÁNH GIÁ 360</div>
                <h1><span class="highlight">Đánh giá năng lực đa chiều</span></h1>
                <div class="hero-desc">
                    <p>Khảo sát nhằm ghi nhận mức độ hợp tác, giao tiếp, hỗ trợ và tinh thần trách nhiệm trong công việc dựa trên đánh giá từ cấp trên, cấp dưới và đồng nghiệp.</p>
                    <p class="jp-text">調査は、上司・部下・同僚からの多角的な評価に基づき、協力、コミュニケーション、サポート、責任感を記録することを目的としています。</p>
                    <div class="result-note">
                        <span>✨ Kết quả là cơ sở để trao đổi 1-1 và cải thiện môi trường làm việc tích cực</span>
                    </div>
                </div>
            </div>

            <!-- PHẦN 2: THANG ĐIỂM - Dạng tham chiếu nhanh -->
            <div class="score-legend">
                <h3>📊 Thang điểm tham chiếu</h3>
                <div class="legend-grid">
                    <div class="legend-item"><span class="score-badge">5</span><strong>Rất tốt</strong><span class="vi-desc">Luôn thực hiện tốt, chủ động hỗ trợ</span><span class="jp-desc">常に高いレベルで実施</span></div>
                    <div class="legend-item"><span class="score-badge">4</span><strong>Tốt</strong><span class="vi-desc">Thực hiện tốt hầu hết trường hợp</span><span class="jp-desc">多くの場面で良好</span></div>
                    <div class="legend-item"><span class="score-badge">3</span><strong>Bình thường</strong><span class="vi-desc">Hoàn thành công việc cơ bản</span><span class="jp-desc">基本的な業務を遂行</span></div>
                    <div class="legend-item"><span class="score-badge">2</span><strong>Cần cải thiện</strong><span class="vi-desc">Chưa đáp ứng một số khía cạnh</span><span class="jp-desc">いくつかの点で改善必要</span></div>
                    <div class="legend-item"><span class="score-badge">1</span><strong>Kém</strong><span class="vi-desc">Chưa đạt yêu cầu</span><span class="jp-desc">期待を満たしていない</span></div>
                </div>
            </div>

            <!-- PHẦN 3: THÔNG TIN NHÂN VIÊN -->
            <div class="employee-section">
                <div class="info-row">
                    <div class="info-field">
                        <label>👤 Mã nhân viên</label>
                        <input type="text" placeholder="VD: NV001" id="employee_id">
                    </div>
                    <div class="info-field">
                        <label>🏢 Group / Phòng ban</label>
                        <input type="text" placeholder="VD: Nhóm Phát triển" id="employee_group">
                    </div>
                </div>
            </div>

            <!-- PHẦN 4: ĐÁNH GIÁ CHI TIẾT 5 GROUP -->
            <div class="evaluation-groups">
                <h3>🎯 Đánh giá theo 5 nhóm năng lực</h3>

                <!-- Group 1 -->
                <div class="group-card">
                    <div class="card-header">
                        <div class="group-num">01</div>
                        <div class="group-name">
                            <h4>Hợp tác & Làm việc nhóm</h4>
                            <span>協働・チームワーク</span>
                        </div>
                    </div>
                    <div class="card-criteria">
                        <span>✓ Phối hợp hiệu quả với thành viên trong và ngoài nhóm</span> <span>✓ Thái độ hợp tác trong quá trình làm việc</span> <span>✓ Sẵn sàng chia sẻ thông tin, hỗ trợ đồng đội</span>
                    </div>
                    <div class="evaluation-fields">
                        <div class="field"><label>📝 Điểm tốt</label><input type="text" placeholder="VD: Luôn support team" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>⚠️ Cần cải thiện</label><input type="text" placeholder="VD: Cần chủ động hơn" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>📌 Tình huống</label><input type="text" placeholder="VD: Dự án X" class="text-input"></div>
                    </div>
                </div>

                <!-- Group 2 -->
                <div class="group-card">
                    <div class="card-header">
                        <div class="group-num">02</div>
                        <div class="group-name">
                            <h4>Giao tiếp & Chia sẻ thông tin</h4>
                            <span>コミュニケーション・情報共有</span>
                        </div>
                    </div>
                    <div class="card-criteria">
                        <span>✓ Giao tiếp tôn trọng, phù hợp với đối tượng</span> <span>✓ Truyền đạt thông tin rõ ràng, dễ hiểu</span> <span>✓ Chủ động báo cáo tiến độ công việc</span> <span>✓ Phản hồi kịp thời khi được liên hệ</span>
                    </div>
                    <div class="evaluation-fields">
                        <div class="field"><label>📝 Điểm tốt</label><input type="text" placeholder="VD: Thông báo rõ ràng tiến độ qua Slack" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>⚠️ Cần cải thiện</label><input type="text" placeholder="VD: Gửi tóm tắt hàng ngày sau cuộc họp" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>📌 Tình huống</label><input type="text" placeholder="VD: Sprint Y - cập nhật tiến độ tính năng Z" class="text-input"></div>
                    </div>
                </div>

                <!-- Group 3 -->
                <div class="group-card">
                    <div class="card-header">
                        <div class="group-num">03</div>
                        <div class="group-name">
                            <h4>Đào tạo & Hỗ trợ người khác</h4>
                            <span>教育・他者支援</span>
                        </div>
                    </div>
                    <div class="card-criteria">
                        <span>✓ Sẵn sàng chia sẻ kiến thức, kinh nghiệm</span> <span>✓ Hỗ trợ thành viên khác trong công việc</span> <span>✓ Đóng góp vào sự phát triển chung của nhóm</span>
                    </div>
                    <div class="evaluation-fields">
                        <div class="field"><label>📝 Điểm tốt</label><input type="text" placeholder="VD: Hướng dẫn member mới về codebase" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>⚠️ Cần cải thiện</label><input type="text" placeholder="VD: Lên tài liệu training rõ ràng hơn" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>📌 Tình huống</label><input type="text" placeholder="VD: Buổi mentor tuần 3 - demo kỹ thuật" class="text-input"></div>
                    </div>
                </div>

                <!-- Group 4 -->
                <div class="group-card">
                    <div class="card-header">
                        <div class="group-num">04</div>
                        <div class="group-name">
                            <h4>Tinh thần trách nhiệm & Tự chủ</h4>
                            <span>責任感・主体性</span>
                        </div>
                    </div>
                    <div class="card-criteria">
                        <span>✓ Chủ động trong công việc được giao</span> <span>✓ Theo dõi và hoàn thành công việc đến cùng</span> <span>✓ Có trách nhiệm với kết quả công việc, không né tránh</span>
                    </div>
                    <div class="evaluation-fields">
                        <div class="field"><label>📝 Điểm tốt</label><input type="text" placeholder="VD: Hoàn thành task trước deadline" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>⚠️ Cần cải thiện</label><input type="text" placeholder="VD: Cần theo dõi ticket thường xuyên hơn" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>📌 Tình huống</label><input type="text" placeholder="VD: Dự án B - xử lý bug sau phát hành" class="text-input"></div>
                    </div>
                </div>

                <!-- Group 5 -->
                <div class="group-card">
                    <div class="card-header">
                        <div class="group-num">05</div>
                        <div class="group-name">
                            <h4>Kỷ luật & Tuân thủ thời gian làm việc</h4>
                            <span>規律遵守・勤務時間管理</span>
                        </div>
                    </div>
                    <div class="card-criteria">
                        <span>✓ Tuân thủ thời gian làm việc (đi làm, nghỉ)</span> <span>✓ Quản lý thời gian hiệu quả, tránh ảnh hưởng tiến độ</span> <span>✓ Chủ động thông báo khi có thay đổi / chậm trễ</span>
                    </div>
                    <div class="evaluation-fields">
                        <div class="field"><label>📝 Điểm tốt</label><input type="text" placeholder="VD: Đi làm đúng giờ, nghỉ đúng quy định" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>⚠️ Cần cải thiện</label><input type="text" placeholder="VD: Cần giảm số lần trễ ca" class="text-input"></div>
                        <div class="field"><label>⭐ Chấm điểm</label><select class="score-select"><option>--</option><option>1</option><option>2</option><option>3</option><option>4</option><option>5</option></select></div>
                        <div class="field"><label>📌 Tình huống</label><input type="text" placeholder="VD: Nghỉ phép đột xuất - thông báo kịp thời" class="text-input"></div>
                    </div>
                </div>
            </div>

            <!-- PHẦN 5: ĐỀ XUẤT & GỬI -->
            <div class="action-section">
                <div class="proposal-box">
                    <h3>💡 Đề xuất cải tiến</h3>
                    <textarea placeholder="Nhập đề xuất cải tiến (nếu có)..." class="proposal-textarea"></textarea>
                    <div class="jp-hint">改善提案があればご記入ください</div>
                </div>

                <div class="submit-wrap">
                    <button type="submit" class="submit-btn">✓ Gửi đánh giá</button>
                </div>
            </div>
        </div>
    </form>
</div>
@section Scripts {
    <script src="~/js/Index.js" asp-append-version="true"></script>
}
